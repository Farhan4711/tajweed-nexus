# ══════════════════════════════════════════════════
# Q.LMS — Environment Variables
# Copy this file to .env.local and fill in values
# ══════════════════════════════════════════════════

# ── Database ──────────────────────────────────────
DATABASE_URL="postgresql://qlms:qlms_dev_password@localhost:5432/qlms?schema=public"

# ── Redis ─────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── NextAuth.js ───────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"

# ── Stripe (Phase 3) ─────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── Daily.co Video (Phase 3) ─────────────────────
DAILY_API_KEY=""
DAILY_API_URL="https://api.daily.co/v1"

# ── Resend Email (Phase 3) ────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@your-domain.com"

# ── Cloudflare R2 / AWS S3 (Phase 3) ─────────────
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="qlms-uploads"
S3_REGION="auto"

# ── App Config ────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Q.LMS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_DOMAIN="localhost"

# ── Meilisearch (Phase 5) ────────────────────────
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY=""

# ── Sentry (Phase 5) ─────────────────────────────
SENTRY_DSN=""

# ── PostHog Analytics (Phase 5) ───────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
